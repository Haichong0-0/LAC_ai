# Anthropic API key for QA generation.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model id. claude-haiku-4-5 is the cost/latency-friendly default;
# swap to claude-sonnet-4-6 for higher-quality answers.
LAC_LLM_MODEL=claude-haiku-4-5

# Embedding model id (HuggingFace). Local sentence-transformers model.
LAC_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Top-K for retrieval.
LAC_TOP_K=5

# Minimum top-1 retrieval score (1 - cosine distance) for `lac ask` / POST /ask
# to call the LLM. Below this, the system short-circuits to the fixed IDK
# sentence. Calibrated against the eval — the lowest answerable top-1 score
# observed is 0.701 (Agda), the highest unanswerable is 0.609.
LAC_MIN_SCORE=0.65

# Persistent Chroma directory (relative to project root).
LAC_CHROMA_DIR=./chroma_db

# Chroma collection name.
LAC_COLLECTION=corpus

# Paths to the title list and corpus JSONL.
LAC_TITLE_LIST=./data/title_list.json
LAC_CORPUS_PATH=./data/corpus.jsonl
